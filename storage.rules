rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /pets/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /stories/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /posters/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
